[Unit]
Description=AVP-Py autonomous video player
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=@RUN_USER@
Group=@RUN_USER@
SupplementaryGroups=audio video input render
WorkingDirectory=@INSTALL_DIR@
Environment=AVPPY_DATA_DIR=@DATA_DIR@
Environment=PYTHONUNBUFFERED=1
ExecStart=@INSTALL_DIR@/.venv/bin/uvicorn avppy.app:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target

